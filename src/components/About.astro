---
/**
 * About.astro — About Me section featuring a professional summary, experience stats, and specializations.
 */
import { portfolio } from '@config/portfolio';
import SectionHeading from '@components/SectionHeading.astro';

const { about, yearsOfExperience, specializations, projects } = portfolio;

// Simple project count calculation or fallback
const projectCount = projects.length || 8;
---

<section id="about" class="section-padding">
  <div class="section-container">
    <SectionHeading title="About Me" subtitle="My professional profile and core competencies" />

    <div class="grid lg:grid-cols-12 gap-12 items-start reveal">
      <!-- Left Column: Biography -->
      <div class="lg:col-span-7 space-y-6">
        <h3 class="heading-md text-[var(--color-text)]">
          Pioneering the next generation of AI systems
        </h3>
        
        {about.split('\n\n').map((paragraph) => (
          <p class="body-md">
            {paragraph}
          </p>
        ))}
      </div>

      <!-- Right Column: Stats & Experience Card -->
      <div class="lg:col-span-5 space-y-6">
        <div class="glass-card p-6 flex flex-col justify-center items-center text-center">
          <div class="text-5xl font-extrabold text-gradient mb-2">
            {yearsOfExperience}+
          </div>
          <div class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-secondary)]">
            Years of Experience
          </div>
        </div>

        <div class="glass-card p-6 flex flex-col justify-center items-center text-center">
          <div class="text-5xl font-extrabold text-gradient mb-2">
            {projectCount}+
          </div>
          <div class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-secondary)]">
             Projects Built
          </div>
        </div>

        <div class="glass-card p-6">
          <h4 class="font-bold text-[var(--color-text)] mb-4 text-center">
            Specialization Areas
          </h4>
          <ul class="space-y-3">
            {specializations.map((spec) => (
              <li class="flex items-center gap-3 text-sm text-[var(--color-text-secondary)]">
                <span class="w-2 h-2 rounded-full bg-primary-500"></span>
                {spec}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
