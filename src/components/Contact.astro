---
/**
 * Contact.astro — Contact info details and interactive contact form.
 */
import { portfolio } from '@config/portfolio';
import SectionHeading from '@components/SectionHeading.astro';

const { email, phone, location } = portfolio;
---

<section id="contact" class="section-padding">
  <div class="section-container">
    <SectionHeading title="Get In Touch" subtitle="Let's build something amazing together" />

    <div class="grid lg:grid-cols-12 gap-12 items-start reveal">
      <!-- Info Left -->
      <div class="lg:col-span-5 space-y-6">
        <h3 class="heading-md text-[var(--color-text)]">
          Contact Details
        </h3>
        <p class="body-md">
          Feel free to reach out for project inquiries, collaboration opportunities, or general technical discussions.
        </p>

        <div class="space-y-4">
          <!-- Email -->
          <div class="glass-card-hover p-4 flex items-center gap-4">
            <div class="p-3 rounded-xl bg-primary-100 dark:bg-primary-950/40 text-primary-600 dark:text-primary-400">
              <span class="i-carbon-email w-6 h-6 block"></span>
            </div>
            <div>
              <div class="text-xs text-[var(--color-text-muted)] font-semibold uppercase tracking-wider">Email</div>
              <a href={`mailto:${email}`} class="text-sm font-semibold text-[var(--color-text)] hover:text-primary-500 transition-colors">
                {email}
              </a>
            </div>
          </div>

          <!-- Phone -->
          <div class="glass-card-hover p-4 flex items-center gap-4">
            <div class="p-3 rounded-xl bg-accent-100 dark:bg-accent-950/40 text-accent-600 dark:text-accent-400">
              <span class="i-carbon-phone w-6 h-6 block"></span>
            </div>
            <div>
              <div class="text-xs text-[var(--color-text-muted)] font-semibold uppercase tracking-wider">Phone</div>
              <a href={`tel:${phone}`} class="text-sm font-semibold text-[var(--color-text)] hover:text-accent-500 transition-colors">
                {phone}
              </a>
            </div>
          </div>

          <!-- Location -->
          <div class="glass-card-hover p-4 flex items-center gap-4">
            <div class="p-3 rounded-xl bg-primary-100 dark:bg-primary-950/40 text-primary-600 dark:text-primary-400">
              <span class="i-carbon-map w-6 h-6 block"></span>
            </div>
            <div>
              <div class="text-xs text-[var(--color-text-muted)] font-semibold uppercase tracking-wider">Location</div>
              <div class="text-sm font-semibold text-[var(--color-text)]">
                {location}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Form Right -->
      <div class="lg:col-span-7">
        <form
          action="#"
          method="POST"
          class="glass-card p-8 space-y-6"
          id="contact-form"
        >
          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-text-secondary)] mb-2">
                Name
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 bg-[var(--color-bg-alt)] border border-[var(--color-border)] focus:border-primary-500 focus:outline-none rounded-xl text-sm transition-colors"
                placeholder="John Doe"
              />
            </div>

            <div>
              <label for="email" class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-text-secondary)] mb-2">
                Email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 bg-[var(--color-bg-alt)] border border-[var(--color-border)] focus:border-primary-500 focus:outline-none rounded-xl text-sm transition-colors"
                placeholder="john@example.com"
              />
            </div>
          </div>

          <div>
            <label for="subject" class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-text-secondary)] mb-2">
              Subject
            </label>
            <input
              type="text"
              id="subject"
              name="subject"
              required
              class="w-full px-4 py-3 bg-[var(--color-bg-alt)] border border-[var(--color-border)] focus:border-primary-500 focus:outline-none rounded-xl text-sm transition-colors"
              placeholder="Collaboration Proposal"
            />
          </div>

          <div>
            <label for="message" class="block text-xs font-semibold uppercase tracking-wider text-[var(--color-text-secondary)] mb-2">
              Message
            </label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-3 bg-[var(--color-bg-alt)] border border-[var(--color-border)] focus:border-primary-500 focus:outline-none rounded-xl text-sm transition-colors resize-none"
              placeholder="Tell me more about your project..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="btn-primary w-full justify-center"
          >
            Send Message
            <span class="i-carbon-send w-5 h-5"></span>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
