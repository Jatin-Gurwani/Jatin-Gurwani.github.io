---
/**
 * Certifications.astro — Display credentials and certifications.
 */
import { portfolio } from '@config/portfolio';
import SectionHeading from '@components/SectionHeading.astro';

const { certifications } = portfolio;
---

<section id="certifications" class="section-padding">
  <div class="section-container">
    <SectionHeading title="Certifications" subtitle="Professional validations and course completions" />

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {certifications.map((cert, idx) => (
        <div
          class="glass-card-hover p-6 flex flex-col justify-between reveal"
          style={`transition-delay: ${idx * 50}ms`}
        >
          <div>
            <div class="text-3xl mb-4" role="img" aria-label="badge">
              {cert.badgeIcon || '🏅'}
            </div>
            <h3 class="font-bold text-lg text-[var(--color-text)] mb-1">
              {cert.name}
            </h3>
            <p class="text-sm font-semibold text-primary-500 mb-2">
              {cert.issuer}
            </p>
            <p class="text-xs text-[var(--color-text-muted)] font-mono mb-4">
              Issued {cert.date}
            </p>
          </div>

          <a
            href={cert.credentialUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-xs font-semibold text-[var(--color-text-secondary)] hover:text-accent-500 transition-colors mt-4 self-start"
          >
            View Credential
            <span class="i-carbon-launch w-3 h-3"></span>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
