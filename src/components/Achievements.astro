---
/**
 * Achievements.astro — Highlight milestones, publications, hackathons, and open source contributions.
 */
import { portfolio } from '@config/portfolio';
import SectionHeading from '@components/SectionHeading.astro';

const { achievements } = portfolio;

// Group achievements by category
const categorized = {
  award: { label: 'Awards', icon: '🏆', colorClass: 'border-amber-500/20 text-amber-500 bg-amber-50 dark:bg-amber-950/20' },
  publication: { label: 'Publications', icon: '📝', colorClass: 'border-blue-500/20 text-blue-500 bg-blue-50 dark:bg-blue-950/20' },
  'open-source': { label: 'Open Source', icon: '🌟', colorClass: 'border-emerald-500/20 text-emerald-500 bg-emerald-50 dark:bg-emerald-950/20' },
  hackathon: { label: 'Hackathons', icon: '🚀', colorClass: 'border-purple-500/20 text-purple-500 bg-purple-50 dark:bg-purple-950/20' },
};
---

<section id="achievements" class="section-padding bg-[var(--color-bg-alt)]">
  <div class="section-container">
    <SectionHeading title="Achievements" subtitle="Notable awards, contributions, and milestones" />

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {achievements.map((item, idx) => {
        const cat = categorized[item.category] || categorized.award;
        return (
          <div
            class="glass-card-hover p-6 flex flex-col justify-between reveal"
            style={`transition-delay: ${idx * 50}ms`}
          >
            <div>
              <!-- Header -->
              <div class="flex items-center justify-between mb-4">
                <span class={`text-sm font-semibold px-3 py-1 rounded-full border ${cat.colorClass}`}>
                  {cat.icon} {cat.label}
                </span>
                <span class="text-xs text-[var(--color-text-muted)] font-mono">
                  {item.date}
                </span>
              </div>

              <!-- Title & Desc -->
              <h3 class="font-bold text-[var(--color-text)] mb-2">
                {item.title}
              </h3>
              <p class="body-md text-sm">
                {item.description}
              </p>
            </div>

            <!-- Optional Link -->
            {item.link && (
              <a
                href={item.link}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1 text-xs font-semibold text-primary-500 hover:underline mt-6 self-start"
              >
                Read More
                <span class="i-carbon-launch w-3 h-3"></span>
              </a>
            )}
          </div>
        );
      })}
    </div>
  </div>
</section>
